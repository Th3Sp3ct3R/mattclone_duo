{
  "name": "julio",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": ">=18"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "whatsapp-report/packages/*",
    "whatsapp-report/apps/*"
  ],
  "scripts": {
    "dev": "PORT=5175 NODE_ENV=development yarn workspace @julio/web-next start:single",
    "dev:web": "yarn workspace @julio/web-next dev",
    "dev:api": "yarn workspace @julio/api dev",
    "dev:worker": "yarn workspace @julio/worker dev",
    "dev:whatsapp": "yarn workspace @julio/whatsapp-app dev",
    "dev:mobile": "yarn workspace @julio/mobile dev",
    "build": "yarn workspaces run build",
    "build:web": "yarn workspace @julio/web-next build",
    "start": "yarn workspace @julio/web-next start:single",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest -c jest.config.js",
    "lint": "eslint . && yarn workspaces run lint",
    "add:web": "yarn workspace @julio/web-next add",
    "add:api": "yarn workspace @julio/api add",
    "add:mobile": "yarn workspace @julio/mobile add",
    "add:pkg": "node ./scripts/add-pkg.js",
    "set:project": "node ./scripts/set-project.mjs",
    "seed:users": "yarn workspace @julio/api seed:users",
    "seed:blog": "yarn workspace @julio/api seed:blog",
    "seed:engine": "yarn workspace @julio/api seed:engine",
    "seed:all": "yarn workspace @julio/api seed:all",
    "import:authorized-accounts": "yarn workspace @julio/api import:authorized-accounts"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.17.0",
    "globals": "^15.13.0",
    "jest": "^29.7.0"
  }
}

