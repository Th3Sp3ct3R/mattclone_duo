{
  "name": "@julio/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.js",
    "./app": "./src/app.js",
    "./auth/*": "./src/auth/*.js",
    "./config/*": "./src/config/*.js",
    "./controllers/*": "./src/controllers/*.controller.js",
    "./cron": "./src/cron/index.js",
    "./cron/*": "./src/cron/*.js",
    "./db/*": "./src/db/*.js",
    "./email/*": "./src/email/*.js",
    "./logger": "./src/logger.js",
    "./models/*": "./src/models/*.model.js",
    "./queue/*": "./src/queue/*.js",
    "./routes/*": "./src/routes/*.js",
    "./routes/v1/index": "./src/routes/v1/index.js",
    "./routes/v1/*": "./src/routes/v1/*.route.js",
    "./services/*": "./src/services/*.service.js",
    "./utils/*": "./src/utils/*.js"
  },
  "scripts": {
    "dev": "node --watch ./src/index.js",
    "start": "node ./src/index.js",
    "build": "node -e \"console.log('api: no build step')\"",
    "lint": "eslint .",
    "seed:users": "node ./scripts/seed-users.mjs",
    "seed:blog": "node ./scripts/seed-blog.mjs",
    "seed:engine": "node ./scripts/seed-engine.mjs",
    "seed:all": "node ./scripts/seed-all.mjs",
    "sync:duoplus": "node ./scripts/sync-duoplus.mjs",
    "import:authorized-accounts": "node ./scripts/import-authorized-accounts.mjs",
    "capture:session": "node ./scripts/capture-session.mjs",
    "frames:duoplus": "node ./scripts/duoplus-frames.mjs",
    "migrate:legacy": "node ./scripts/migrate-legacy.mjs",
    "patch:blog:longform": "node ./scripts/patch-blog-longform.mjs",
    "onboard:account": "node ./bin/onboard-account.mjs",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest -c jest.config.js --passWithNoTests"
  },
  "dependencies": {
    "@julio/assets": "0.1.0",
    "@julio/automation": "0.1.0",
    "@julio/booking": "0.1.0",
    "@julio/chatbot": "0.1.0",
    "@julio/config": "0.1.0",
    "@julio/device-control": "0.1.0",
    "@julio/integrations": "0.1.0",
    "@julio/intelligence": "0.1.0",
    "@julio/logger": "0.1.0",
    "@julio/media": "0.1.0",
    "@julio/payments": "0.1.0",
    "@julio/shared": "0.1.0",
    "amqplib": "^0.10.4",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "graphql": "^16.8.1",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.7.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.14",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "eslint": "^9.17.0"
  }
}
