MONGODB_URI=mongodb://localhost:27017/julio
JWT_SECRET=change_me
REDIS_URL=redis://localhost:6379
RABBITMQ_URL=amqp://localhost

AWS_REGION=blah
AWS_ACCESS_KEY_ID=blah
AWS_SECRET_ACCESS_KEY=blah
AWS_S3_BUCKET=blah
AWS_PUBLIC_BASE_URL=blah
AWS_MAX_UPLOAD_BYTES=blah

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=change_me
SMTP_PASS=change_me

# Mobile (Expo) API base URL (public)
EXPO_PUBLIC_API_URL=http://localhost:4000
# Web (Next.js) API base URL (public)
NEXT_PUBLIC_API_URL=http://localhost:4000

HUGGINGFACE_API_KEY=blah
HUGGINGFACE_CHAT_MODEL=blah

# Engine provider
CLOUD_PROVIDER=vmos
VMOS_ACCESS_KEY=
VMOS_SECRET_KEY=
DUOPLUS_API_KEY=
DUOPLUS_API_BASE_URL=https://openapi.duoplus.net
DUOPLUS_MIN_DELAY_MS=1100
DUOPLUS_FOCUS_STREAM_ENABLED=false
DUOPLUS_APP_SET=TikTok,Instagram
DUOPLUS_SESSION_FILE=./duoplus-session.json

# Optional monitoring
SENTRY_DSN=
SENTRY_RELEASE=

# LLM providers used by automation/media workflows
OPENAI_API_KEY=
OPENAI_ORG_ID=
OPENAI_PROJECT_ID=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# Public URL for device downloads
ENGINE_PUBLIC_URL=
INSTAGRAM_APK_URL=
TIKTOK_APK_URL=
CHROME_APK_URL=
YOUTUBE_APK_URL=
YOUTUBE_MUSIC_APK_URL=
SPOTIFY_APK_URL=
APPLE_MUSIC_APK_URL=
REDDIT_APK_URL=
X_APK_URL=
TELEGRAM_APK_URL=
LINKEDIN_APK_URL=
THREADS_APK_URL=
SAI_APK_URL=
SUNO_XAPK_URL=

# Cloudflare R2 (S3-compatible APK/media storage)
CF_R2_ACCOUNT_ID=
CF_R2_ACCESS_KEY_ID=
CF_R2_SECRET_ACCESS_KEY=
CF_R2_BUCKET=engine-apks
CF_R2_PUBLIC_URL=

# Account recovery / procurement
DEFAULT_IMAP_SERVER=imap.outlook.com
DEFAULT_IMAP_PORT=993
DJEKXA_API_KEY=
DJEKXA_BASE_URL=
DJEKXA_FX_RUB_PER_USD=90

# Engine worker cadence
MEDIA_DOWNLOAD_DIR=./media
NICHE_DISCOVERY_INTERVAL_MS=1800000
CONTENT_DOWNLOAD_INTERVAL_MS=60000
CONTENT_DOWNLOAD_BATCH_SIZE=5
CROSS_POST_INTERVAL_MS=60000
POST_EXECUTOR_CONCURRENCY=2
PIPELINE_EXECUTOR_CONCURRENCY=2
TRANSFORM_EXECUTOR_CONCURRENCY=2
SESSION_MONITOR_INTERVAL_MS=1800000
PROXY_MONITOR_INTERVAL_MS=1800000
TREND_MATCH_INTERVAL_MS=21600000

# Authorized account import — secret resolver env vars
# Used when password_secret_ref uses env: scheme
# TIKTOK_PASSWORD=
# INSTAGRAM_PASSWORD=
# YOUTUBE_PASSWORD=

# --- Mass WhatsApp Report service (@julio/whatsapp-app) ---
# Reuses MONGODB_URI / REDIS_URL / RABBITMQ_URL (above).
# Reuses DUOPLUS_API_KEY / DUOPLUS_API_BASE_URL / DUOPLUS_MIN_DELAY_MS (above).
WHATSAPP_POOL_THRESHOLD=10
WHATSAPP_DEVICE_TARGET_DEPTH=3
WHATSAPP_BUY_BATCH_SIZE=5
WHATSAPP_PROBE_CRON=*/15 * * * *
WHATSAPP_AUTOBUY_ENABLED=false
# dark.shopping procurement (⚠️ verify real base URL / delivery format before go-live)
DARK_SHOPPING_API_KEY=
DARK_SHOPPING_BASE_URL=
# Procurement price guards. Buy path stays blocked until you set the expected unit
# price (adapter fails safe with PROCUREMENT_PRICE_DRIFT otherwise).
WHATSAPP_EXPECTED_UNIT_USD_CENTS=
WHATSAPP_MAX_TOTAL_USD_CENTS=
WHATSAPP_PRICE_DRIFT_TOLERANCE=0.1
# WhatsApp team-APK (⚠️ verify team app id from the DuoPlus team catalog)
WHATSAPP_TEAM_APP_ID=
# Optional egress proxy for provisioned cloud phones. Leave blank to skip.
# Either reference a pre-registered proxy by id, or provide host/port/user/password.
DUOPLUS_PROXY_ID=
DUOPLUS_PROXY_HOST=
DUOPLUS_PROXY_PORT=
DUOPLUS_PROXY_USER=
DUOPLUS_PROXY_PASSWORD=
WHATSAPP_APK_URL=
# MCP surface (Plan 6)
WHATSAPP_MCP_HTTP_PORT=7300
WHATSAPP_HEALTH_PORT=7301
WHATSAPP_MCP_AUTH_TOKEN=
LOG_LEVEL=info
